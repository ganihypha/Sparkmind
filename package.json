{
  "name": "sparkmind-sovereign",
  "version": "0.0.0",
  "private": true,
  "description": "SparkMind Sovereign monorepo — mother brand + sub-brands (BarberKas, PaceLokal) + doctrine docs + PoWPL ledger.",
  "license": "MIT",
  "author": "Reza Estes / Haidar (Sovereign AI Dev)",
  "homepage": "https://github.com/ganihypha/Sparkmind-Sovereign",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ganihypha/Sparkmind-Sovereign.git"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "turbo": "2.1.3",
    "typescript": "5.6.3"
  }
}
