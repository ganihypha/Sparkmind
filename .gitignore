# ============================================================================
# SparkMind Sovereign — Monorepo .gitignore
# ============================================================================

# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
out/
.next/
.turbo/
.wrangler/
*.tsbuildinfo

# Cloudflare / Wrangler
.dev.vars
.dev.vars.*
wrangler.toml.local

# Environment / secrets — NEVER COMMIT
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
.idea/

# Coverage
coverage/
.nyc_output/

# Misc
*.tgz
.cache/
.eslintcache
.prettiercache

# PM2 (dev only — not used in production deploys)
.pm2/
pids/

# Backups
*.backup
*.bak
